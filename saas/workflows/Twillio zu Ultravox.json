    {
      "parameters": {
        "jsCode": "// TwiML Response for twillio\nconst joinUrl = $input.first().json.joinUrl\nconst callSid = $('Webhook').first().json.body.CallSid\nconst callerNumber = $('Webhook').first().json.body.Caller\n\n// check if valid joinUrl\n// HIER: 'lenght' MUSS 'length' sein!\nif (joinUrl && joinUrl.length > 0) {\n  // create TwiML with Ultravox connection\n  const twiml = `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n    <Response>\n      <Connect>\n        <Stream url=\"${joinUrl}\">\n          <Parameter name=\"customerId\" value=\"${callerNumber}\"/> \n          <Parameter name=\"callSid\" value=\"${callSid}\"/>\n        </Stream>\n      </Connect>\n    </Response>`\n    \n  // RICHTIGER RÜCKGABEWERT FÜR N8N CODE NODE\n  return [\n    {\n      json: {\n        twiml\n      }\n    }\n  ];\n} else {\n  // fallback TwiML, z.B. eine Ansage\n  const twiml = `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n    <Response>\n      <Say>Entschuldigung, der Dienst ist momentan nicht erreichbar. Bitte rufen Sie später erneut an.</Say>\n    </Response>`\n    \n  // RICHTIGER RÜCKGABEWERT FÜR N8N CODE NODE\n  return [\n    {\n      json: {\n        twiml\n      }\n    }\n  ];\n}"
      },
